<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- 先绘制半透明遮罩（底层），点击空白处关闭；内容卡片在上层可正常点击 -->
    <View
        android:id="@+id/optionsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/optionsContentCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="0dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="32dp">

        <!-- 波形颜色：预设一行，当前颜色单独一行，点击色块弹出 RGB -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/waveform_color"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <View
                android:id="@+id/btnWaveformPreset1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@color/waveform_preset_1"
                android:contentDescription="青蓝"
                android:layout_marginEnd="6dp" />
            <View
                android:id="@+id/btnWaveformPreset2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@color/waveform_preset_2"
                android:contentDescription="绿色"
                android:layout_marginEnd="6dp" />
            <View
                android:id="@+id/btnWaveformPreset3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@color/waveform_preset_3"
                android:contentDescription="橙色"
                android:layout_marginEnd="6dp" />
            <View
                android:id="@+id/btnWaveformPreset4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@color/waveform_preset_4"
                android:contentDescription="粉色" />
        </LinearLayout>
        <!-- 当前颜色一行：色块左侧，RGB 滑块在色块右侧（点击色块展开/收起） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_color"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="10dp" />
            <View
                android:id="@+id/waveformColorPreview"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/waveform_color"
                android:contentDescription="@string/click_color_to_adjust"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />
            <TextView
                android:id="@+id/waveformColorHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/click_color_to_adjust"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
            <LinearLayout
                android:id="@+id/waveformRgbSliders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="gone"
                android:minWidth="120dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="R"
                        android:textColor="@color/primary_light"
                        android:textSize="11sp" />
                    <SeekBar
                        android:id="@+id/seekBarWaveformR"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="255"
                        android:progress="56" />
                    <TextView
                        android:id="@+id/tvWaveformR"
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:gravity="end" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="G"
                        android:textColor="@color/primary_light"
                        android:textSize="11sp" />
                    <SeekBar
                        android:id="@+id/seekBarWaveformG"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="255"
                        android:progress="189" />
                    <TextView
                        android:id="@+id/tvWaveformG"
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:gravity="end" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="B"
                        android:textColor="@color/primary_light"
                        android:textSize="11sp" />
                    <SeekBar
                        android:id="@+id/seekBarWaveformB"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="255"
                        android:progress="248" />
                    <TextView
                        android:id="@+id/tvWaveformB"
                        android:layout_width="24dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="8dp" />

        <!-- 频率缩放：线性/对数/十二平均律 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/frequency_scale"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleLinear"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/linear_scale"
                android:textSize="12sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleLog"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/log_scale"
                android:textSize="12sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScaleTwelveTet"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/twelve_tet_scale"
                android:textSize="11sp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- 频谱斜率 -12dB～12dB，步进 3dB，默认 0 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/spectrum_slope"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleSlope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlopeNeg12"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-12"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlopeNeg9"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-9"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlopeNeg6"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-6"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlopeNeg3"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-3"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlope0"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlope3"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlope6"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="6"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlope9"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="9"
                android:textSize="11sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlope12"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12"
                android:textSize="11sp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- 增益 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gain"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <SeekBar
                android:id="@+id/seekBarGainSheet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="200"
                android:progress="100" />
            <TextView
                android:id="@+id/tvGainValueSheet"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:text="100%"
                android:gravity="end" />
        </LinearLayout>

        <!-- 频率标记 / 峰值检测 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchFrequencyMarkerSheet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/frequency_marker"
                android:textSize="13sp"
                android:checked="true" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPeakDetectionSheet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/peak_detection"
                android:textSize="13sp"
                android:checked="true" />
        </LinearLayout>

    </LinearLayout>
    </ScrollView>

    </LinearLayout>
</FrameLayout>
